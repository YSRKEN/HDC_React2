{
  "name": "hdc-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "bootstrap": "4.6.2",
    "react": "17.0.2",
    "react-bootstrap": "1.6.8",
    "react-dom": "17.0.2",
    "tslib": "2.8.1"
  },
  "scripts": {
    "start": "vite",
