    "@types/react-dom": "17.0.26",
    "@vitejs/plugin-react": "6.0.1",
    "chart.js": "4.5.1",
    "jsdom": "25.0.1",
    "react-chartjs-2": "5.3.1",
    "typescript": "6.0.2",
    "vite": "8.0.2",
    "vitest": "4.1.1"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
